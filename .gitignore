# Koha ILS source tree — cloned separately by the developer (see README)
# Auto-clone with stack.sh (KOHA_GIT_CLONE_MODE/KOHA_GIT_TAG in env/.env)
koha/

# Runtime secrets and local overrides
env/.env.local

# OpenSearch TLS certificates (generated locally)
OpenSearch-3.6/assets/ssl/*.pem
OpenSearch-3.6/assets/ssl/*.key
OpenSearch-3.6/assets/ssl/*.crt

OpenSearch-3.6/assets/opensearch/data/

# OpenSearch machine-local config (passwords, compliance salt, SQL masterkey).
# Each workstation generates its own values via opensearch_local_certificates_creator.sh.
# Copy OpenSearch-3.6/.env.example to OpenSearch-3.6/.env and run the script on first use.
OpenSearch-3.6/.env

# Editor / OS noise
.DS_Store
*.swp
*.swo
*~

# Do not push backups
backups/
