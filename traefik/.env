# Traefik DNS provider credentials

# Host port bindings for the Traefik proxy container.
# Change TRAEFIK_HTTP_PORT to a non-privileged port (e.g. 8000) if port 80 is
# already in use on the host, then access Koha as http://hostname:8000
TRAEFIK_HTTP_PORT=8000
TRAEFIK_HTTPS_PORT=8443
TRAEFIK_DASHBOARD_PORT=8083

# ── Let's Encrypt (ACME) ─────────────────────────────────────────────────────
# Contact email for Let's Encrypt certificate registration.
#
# Requirements before enabling:
#   1. This must be a valid, monitored address (used for expiry notices).
#   2. TRAEFIK_HTTP_PORT (port 80) must be reachable from the internet — Let's
#      Encrypt uses an HTTP-01 challenge to verify domain ownership.
#   3. KOHA_DOMAIN in env/.env must be a real public domain that resolves to
#      this server's public IP (e.g. .library.example.com, NOT .127.0.0.1.nip.io).
#   4. Set TLS_CERTRESOLVER=letsencrypt in env/.env AND OpenSearch-3.6/.env.
#
# Leave empty for local / offline development.
# When empty, Traefik serves HTTPS with a self-signed fallback certificate
# (browser shows a certificate warning, but HTTP continues to work normally).
ACME_EMAIL=
