DOCKER_BINARY=$(which docker)
DB_HOSTNAME=db
DB_IMAGE=mariadb:10.11
DB_SQL_MODE=STRICT_TRANS_TABLES,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION
KOHA_DB_ROOT_PASSWORD=password
KOHA_IMAGE_TAG=kosson/koha-ubuntu:latest
KOHA_GIT_CLONE_MODE=tag
KOHA_GIT_TAG=v25.11.05-1
KOHA_GIT_BRANCH=main
KOHA_GIT_DEPTH=1
KOHA_GIT_URL=https://git.koha-community.org/Koha-community/Koha.git
EDITOR=vim
ENABLE_IPV4=true
ENABLE_IPV6=false
GIT_BZ_PASSWORD=nothing
GIT_BZ_USER=you@example.com
GIT_USER_EMAIL=you@example.com
GIT_USER_NAME="John Doe"
DEBUG_GIT_REPO_MISC4DEV=no
DEBUG_GIT_REPO_MISC4DEV_URL=https://gitlab.com/koha-community/koha-misc4dev.git
DEBUG_GIT_REPO_MISC4DEV_BRANCH=main
DEBUG_GIT_REPO_QATESTTOOLS=no
DEBUG_GIT_REPO_QATESTTOOLS_URL=https://gitlab.com/koha-community/qa-test-tools.git
DEBUG_GIT_REPO_QATESTTOOLS_BRANCH=main
DEBUG_RUN=no
DEBUG_RUN_URL=https://gitlab.com/joubu/koha-testing-docker/-/raw/test/files/run.sh
KOHA_IMAGE=main
KOHA_CONF=/etc/koha/sites/kohadev/koha-conf.xml
KOHA_DB_PASSWORD=password
KOHA_DOMAIN=.myDNSname.org
KOHA_INSTANCE=kohadev
KOHA_INTRANET_PORT=8081
KOHA_INTRANET_PREFIX=
KOHA_INTRANET_SUFFIX=-intra
KOHA_RABBITMQ_USER=koha
KOHA_RABBITMQ_PASS=password
KOHA_RABBITMQ_VHOST=koha_kohadev
MESSAGE_BROKER_HOST=rabbitmq
MESSAGE_BROKER_PORT=61613
MESSAGE_BROKER_USER=koha
MESSAGE_BROKER_PASS=password
MESSAGE_BROKER_VHOST=koha_kohadev
KOHA_MARC_FLAVOUR=marc21
KOHA_OPAC_PORT=8080
KOHA_OPAC_PREFIX=
KOHA_OPAC_SUFFIX=
KOHA_PASS=koha
KOHA_PROVE_CPUS=
KOHA_USER=koha
MANA_URL=https://mana-test.koha-community.org
PERL5LIB=/kohadevbox/koha:/kohadevbox/koha/lib:/kohadevbox/qa-test-tools
REMOTE_DEBUGGER_KEY=
REMOTE_DEBUGGER_LOCATION=host.docker.internal:9000
SELENIUM_ADDR=selenium
SELENIUM_PORT=4444
KOHA_ELASTICSEARCH=
PLACK_MAX_REQUESTS=50
PLACK_WORKERS=2
ELASTIC_SERVER=es:9200
ELASTIC_OPTIONS=
OPENSEARCH_INITIAL_ADMIN_PASSWORD=pu1kohphei4heeY4pai7ohp6vei4Ea6i
CI_RUN=no
CPAN=no
INSTALL_MISSING_FROM_CPANFILE=no
KEYCLOAK_ADMIN=keycloak
KEYCLOAK_ADMIN_PASS=keycloak
KEYCLOAK_REALM=koha
USE_EXISTING_DB=
SKIP_L10N=
KOHA_DESIRED_LANGUAGES=en,es-ES,ro-RO,ca-ES,hu-HU,de-DE
KOHA_OPAC_LANGUAGES_DISPLAY=1
KOHA_TRANSLATIONS_REINSTALL=no
EXTRA_CPAN=
EXTRA_APT=
ENABLE_SMTP=
SMTP_IMAGE=
ENABLE_PLUGINS=no
