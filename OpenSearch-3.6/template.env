OPEN_SEARCH_VERSION=3.6.0
OPENSEARCH_INITIAL_ADMIN_PASSWORD="test@Cici24#ANA"
ES_PORT=9200
OS_CLUSTER_NAME="opensearch"
OS_SEARCH_SNAPSHOT_SIZE="1gb"
OPENSEARCH_JAVA_OPTS="-Xms1g -Xmx1g"

# ── Dashboards Traefik routing ────────────────────────────────────────────────
# Hostname used for the OpenSearch Dashboards Traefik HTTP and HTTPS routers.
# Default: dashboards.localhost  (local dev — no public DNS required)
# Production: set to a real public hostname, e.g. dashboards.library.example.com
DASHBOARDS_DOMAIN=dashboards.localhost

# ── TLS / Let's Encrypt ───────────────────────────────────────────────────────
# Must match TLS_CERTRESOLVER in env/.env.
# (empty)     → self-signed fallback cert for Dashboards HTTPS
# letsencrypt → Let's Encrypt cert (requires ACME_EMAIL in traefik/.env and a
#               real public DASHBOARDS_DOMAIN that resolves to this host)
TLS_CERTRESOLVER=

# ── Machine-local OpenSearch security values ─────────────────────────────────
# These are generated by opensearch_local_certificates_creator.sh and are
# MACHINE-SPECIFIC. This file is gitignored so each workstation retains its own
# values and git pull never overwrites them.
#
# Both values are referenced as ${OS_COMPLIANCE_SALT} / ${OS_QUERY_MASTERKEY}
# in every node's opensearch.yml; OpenSearch substitutes them at startup.
#
# WARNING: Do NOT change OS_QUERY_MASTERKEY on a running cluster — all previously
# stored SQL datasource credentials would become unreadable. Regenerate only
# when setting up a fresh cluster (after wiping os0{1..5}data/).
OS_COMPLIANCE_SALT=ZLqnAIFnRMj2wTFw
OS_QUERY_MASTERKEY=0217e69bff29bc67dc12c16d84904a85