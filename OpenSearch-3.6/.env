OPEN_SEARCH_VERSION=3.6.0
OPENSEARCH_INITIAL_ADMIN_PASSWORD=test@Cici24#ANA
ES_PORT=9200
OS_CLUSTER_NAME="opensearch"
OS_SEARCH_SNAPSHOT_SIZE="1gb"
OPENSEARCH_JAVA_OPTS="-Xms1g -Xmx1g"

# ── Dashboards Traefik routing ────────────────────────────────────────────────
# Hostname used for the OpenSearch Dashboards Traefik HTTP and HTTPS routers.
# Default: dashboards.localhost  (local dev — no public DNS required)
# Production: set to a real public hostname, e.g. dashboards.library.example.com
DASHBOARDS_DOMAIN=dashboards.localhost

# ── TLS / Let's Encrypt ───────────────────────────────────────────────────────
# Must match TLS_CERTRESOLVER in env/.env.
# (empty)     → self-signed fallback cert for Dashboards HTTPS
# letsencrypt → Let's Encrypt cert (requires ACME_EMAIL in traefik/.env and a
#               real public DASHBOARDS_DOMAIN that resolves to this host)
TLS_CERTRESOLVER=
